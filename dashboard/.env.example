APP_NAME=Lineage Dashboard V2
ENVIRONMENT=production

# Must point to the same PostgreSQL host, port, and database as
# BOT_DATABASE_URL in the root .env. The DB user may differ if it has access.
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5432/lineage_antalas
DB_ECHO=false

# Must be the same dedicated bot token as DISCORD_BOT_TOKEN in the root .env.
DISCORD_BOT_TOKEN=
DISCORD_API_BASE=https://discord.com/api/v10
DISCORD_CACHE_TTL_SECONDS=300
BOT_EVENT_ACK_TIMEOUT_SECONDS=5

# Discord OAuth application settings.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://dashboard.example.com/auth/discord/callback
DISCORD_REDIRECT_URI_LOCAL=http://localhost:8000/auth/discord/callback

# Use a long random value and never reuse the example.
SESSION_SECRET=change-this-to-a-long-random-value
SESSION_HTTPS_ONLY=true
AUTH_LOCAL_BYPASS=false
