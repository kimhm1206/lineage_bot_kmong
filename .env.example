# Branch-local runtime database. Web and bot processes only use this SQLite file.
SQLITE_DATABASE_PATH=data/new_server_workspace.sqlite3

# Production PostgreSQL is read only by scripts/clone_recent_postgres_to_sqlite.py.
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=

# Web/bot integration values can be copied from the deployment environment as needed.
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:8000/auth/discord/callback
WEB_BASE_URL=http://127.0.0.1:8000
