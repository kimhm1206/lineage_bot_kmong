{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "starttest",
      "type": "shell",
      "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "uvicorn",
        "web.app:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "LINEAGE_DB_TARGET": "test"
        }
      },
      "problemMatcher": []
    }
  ]
}
