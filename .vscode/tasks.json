{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "starttest",
      "dependsOrder": "parallel",
      "dependsOn": [
        "starttest:web",
        "starttest:bot"
      ],
      "problemMatcher": []
    },
    {
      "label": "starttest:web",
      "type": "shell",
      "command": "${workspaceFolder}\\web\\venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "uvicorn",
        "web.app:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "LINEAGE_DB_TARGET": "test"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "starttest:bot",
      "type": "shell",
      "command": "${workspaceFolder}\\discord_bot\\venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "discord_bot.main",
        "--test"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "LINEAGE_DB_TARGET": "test"
        }
      },
      "problemMatcher": []
    }
  ]
}
